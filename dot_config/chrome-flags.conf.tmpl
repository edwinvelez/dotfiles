# ---------------------------------------------------------
# WAYLAND & DISPLAY
# ---------------------------------------------------------
# Set scaling factor
{{- if eq .chezmoi.hostname "my-desktop" }}
--force-device-scale-factor=1.0
{{- else if eq .chezmoi.hostname "my-laptop" }}
--force-device-scale-factor=1.5
{{- end }}
--ozone-platform-hint=auto
--enable-features=UseOzonePlatform
--ozone-platform=wayland

# ---------------------------------------------------------
# NVIDIA SPECIFIC FIXES (CRITICAL)
# ---------------------------------------------------------
# Fixes flickering/sync issues on NVIDIA 555+ drivers
--enable-features=WaylandWindowDecorations,WaylandLinuxDrmSyncobj

# ---------------------------------------------------------
# VIDEO ACCELERATION (VA-API via NVDEC)
# ---------------------------------------------------------
# Force the browser to use the NVIDIA translation driver
--enable-features=VaapiVideoDecodeLinuxGL,VaapiVideoDecoder
--ignore-gpu-blocklist
--enable-gpu-rasterization
--enable-zero-copy

# Bypass the internal blocklist that disables acceleration on NVIDIA
--disable-features=UseChromeOSDirectVideoDecoder
--enable-features=VaapiIgnoreDriverChecks
